<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_root">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical"
        android:background="@color/bg_surface">

        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/icon_circle_teal">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_catalog"
                android:tint="@color/accent_teal" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Каталог"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textCatalogSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_dim"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Search field with autocomplete history -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="@drawable/search_field_bg">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                android:tint="@color/text_dim" />

            <AutoCompleteTextView
                android:id="@+id/editSearch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:hint="Поиск приложений…"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_dim"
                android:textSize="15sp"
                android:background="@null"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"
                android:maxLines="1"
                android:completionThreshold="1"
                android:dropDownVerticalOffset="8dp" />

            <ImageView
                android:id="@+id/buttonClearSearch"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:src="@drawable/ic_close"
                android:tint="@color/text_dim"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackgroundBorderless" />
        </LinearLayout>

        <!-- Sort button -->
        <FrameLayout
            android:id="@+id/buttonSort"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/icon_button_bg"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_sort"
                android:tint="@color/text_secondary" />
        </FrameLayout>
    </LinearLayout>

    <!-- Filter chips row -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:fillViewport="false"
        android:background="@color/bg_surface"
        android:paddingHorizontal="20dp"
        android:paddingBottom="14dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:paddingHorizontal="18dp"
                android:gravity="center"
                android:text="Все"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/chip_filter"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chipInstalled"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:paddingHorizontal="18dp"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:text="Установлены"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/chip_filter"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chipAvailable"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:paddingHorizontal="18dp"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:text="Доступны к установке"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/chip_filter"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chipPlanned"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:paddingHorizontal="18dp"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:text="Запланированы"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/chip_filter"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </HorizontalScrollView>

    <ListView
        android:id="@+id/listCatalog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false"
        android:divider="@null"
        android:dividerHeight="0dp" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/emptySearchState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_search"
            android:tint="@color/text_dim"
            android:alpha="0.4" />

        <TextView
            android:id="@+id/textEmptySearch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Ничего не найдено"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />
    </LinearLayout>
</LinearLayout>
